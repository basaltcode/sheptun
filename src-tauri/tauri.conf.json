{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sheptun",
  "version": "2.1.4",
  "identifier": "com.basaltcode.sheptun",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:backend && npm run build:frontend",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sheptun",
        "width": 960,
        "height": 1040,
        "minWidth": 720,
        "minHeight": 720,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "nsis", "appimage"],
    "category": "Productivity",
    "copyright": "Copyright 2024 Basalt Code",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/backend/**/*"],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzM0Q1NDI2MDU5NEM2QzMKUldURHhwUUZKbFE5VTVTRVZJb0ZMT1lKcEMrL051dGRzUUxxUE9aclRwYWVISmcxcjFMbzFQZVQK",
      "endpoints": [
        "https://github.com/basaltcode/sheptun/releases/latest/download/latest.json"
      ]
    }
  }
}
